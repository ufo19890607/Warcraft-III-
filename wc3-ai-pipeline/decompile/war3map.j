//===========================================================================
function Trig_ComputerRandomSkill73_Func003001001 takes nothing returns boolean
    return ( udg_RandomNumber > 0 )
endfunction

function Trig_ComputerRandomSkill73_Func003001002 takes nothing returns boolean
    return ( udg_RandomNumber <= 7 )
endfunction

function Trig_ComputerRandomSkill73_Func003001 takes nothing returns boolean
    return GetBooleanAnd((udg_RandomNumber > 0), (udg_RandomNumber <= 7)) // INLINED!!
endfunction

function Trig_ComputerRandomSkill73_Func004001001 takes nothing returns boolean
    return ( udg_RandomNumber > 7 )
endfunction

function Trig_ComputerRandomSkill73_Func004001002 takes nothing returns boolean
    return ( udg_RandomNumber <= 10 )
endfunction

function Trig_ComputerRandomSkill73_Func004001 takes nothing returns boolean
    return GetBooleanAnd((udg_RandomNumber > 7), (udg_RandomNumber <= 10)) // INLINED!!
endfunction

function Trig_ComputerRandomSkill73_Actions takes nothing returns nothing
    // Skill1-100% Skill2-0%
    set udg_RandomNumber=GetRandomInt(1, 10)
    if ( (GetBooleanAnd((udg_RandomNumber > 0), (udg_RandomNumber <= 7))) ) then // INLINED!!
        call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
    else
        call DoNothing()
    endif
    if ( (GetBooleanAnd((udg_RandomNumber > 7), (udg_RandomNumber <= 10))) ) then // INLINED!!
        call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
    else
        call DoNothing()
    endif
endfunction

