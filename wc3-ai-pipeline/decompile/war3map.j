function Trig_CourseName_Actions takes nothing returns nothing
    if ( (udg_P1Race == 0) ) then // INLINED!!
        set udg_P1Race=GetRandomInt(1, 4)
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 0) ) then // INLINED!!
        set udg_P2Race=GetRandomInt(1, 4)
    else
        call DoNothing()
    endif
    set udg_Race1Name=""
    set udg_Race2Name=""
    set udg_Race1Player=Player(0)
    set udg_Race2Player=Player(1)
    set udg_Race1BuildingPlace=gg_rct_P1Build
    set udg_Race2BuildingPlace=gg_rct_P2Build
    set udg_P1BasePlace=gg_rct_P1Base
    set udg_P2BasePlace=gg_rct_P2Base
    set udg_TempCN=S2I(( I2S(udg_P1Race) + I2S(udg_P2Race) ))
    if ( (GetBooleanOr((udg_TempCN == 24), (udg_TempCN == 42))) ) then // INLINED!!
        set udg_Course=1
    else
        call DoNothing()
    endif
    if ( (GetBooleanOr((udg_TempCN == 21), (udg_TempCN == 12))) ) then // INLINED!!
        set udg_Course=2
    else
        call DoNothing()
    endif
    if ( (GetBooleanOr((udg_TempCN == 23), (udg_TempCN == 32))) ) then // INLINED!!
        set udg_Course=3
    else
        call DoNothing()
    endif
    if ( (GetBooleanOr((udg_TempCN == 41), (udg_TempCN == 14))) ) then // INLINED!!
        set udg_Course=4
    else
        call DoNothing()
    endif
    if ( (GetBooleanOr((udg_TempCN == 43), (udg_TempCN == 34))) ) then // INLINED!!
        set udg_Course=5
    else
        call DoNothing()
    endif
    if ( (GetBooleanOr((udg_TempCN == 13), (udg_TempCN == 31))) ) then // INLINED!!
        set udg_Course=6
    else
        call DoNothing()
    endif
    if ( (udg_TempCN == 22) ) then // INLINED!!
        set udg_Course=7
    else
        call DoNothing()
    endif
    if ( (udg_TempCN == 11) ) then // INLINED!!
        set udg_Course=8
    else
        call DoNothing()
    endif
    if ( (udg_TempCN == 33) ) then // INLINED!!
        set udg_Course=9
    else
        call DoNothing()
    endif
    if ( (udg_TempCN == 44) ) then // INLINED!!
        set udg_Course=10
    else
        call DoNothing()
    endif
    if ( Trig_CourseName_Func022C() ) then
        set udg_Race1Player=Player(1)
        set udg_Race2Player=Player(0)
        set udg_Race1BuildingPlace=gg_rct_P2Build
        set udg_Race2BuildingPlace=gg_rct_P1Build
        set udg_P1BasePlace=gg_rct_P2Base
        set udg_P2BasePlace=gg_rct_P1Base
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 1) ) then // INLINED!!
        set udg_Race1Name="人族"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 2) ) then // INLINED!!
        set udg_Race1Name="兽族"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 3) ) then // INLINED!!
        set udg_Race1Name="不死族"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 4) ) then // INLINED!!
        set udg_Race1Name="暗夜精灵族"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 1) ) then // INLINED!!
        set udg_Race2Name="人族"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 2) ) then // INLINED!!
        set udg_Race2Name="兽族"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 3) ) then // INLINED!!
        set udg_Race2Name="不死族"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 4) ) then // INLINED!!
        set udg_Race2Name="暗夜精灵族"
    else
        call DoNothing()
    endif
    call ConditionalTriggerExecute(gg_trg_Research)
    call TriggerSleepAction(0.01)
    call DisplayTimedTextToForce(GetPlayersAll(), 5.00, ( udg_Race1Name + ( "  Vs  " + udg_Race2Name ) ))
    if ( (udg_P1Race == 1) ) then // INLINED!!
        set udg_Race1Name="H"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 2) ) then // INLINED!!
        set udg_Race1Name="O"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 3) ) then // INLINED!!
        set udg_Race1Name="U"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 4) ) then // INLINED!!
        set udg_Race1Name="N"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 1) ) then // INLINED!!
        set udg_Race2Name="H"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 2) ) then // INLINED!!
        set udg_Race2Name="O"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 3) ) then // INLINED!!
        set udg_Race2Name="U"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 4) ) then // INLINED!!
        set udg_Race2Name="N"
    else
        call DoNothing()
    endif
endfunction

