    return GetBooleanAnd((IsUnitAliveBJ(GetFilterUnit()) == true), (IsUnitIdType(GetUnitTypeId(GetFilterUnit()), UNIT_TYPE_STRUCTURE) == false)) // INLINED!!
endfunction

function Trig_Player2Win_Conditions takes nothing returns boolean
    if ( not ( udg_RoundOver == false ) ) then
        return false
    endif
    if ( not ( CountUnitsInGroup(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_Player2Win_Func002001001002))) <= 0 ) ) then
        return false
