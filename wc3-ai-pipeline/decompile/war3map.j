    call TriggerRegisterPlayerChatEvent(gg_trg_P1_Ready_Vs_Com, Player(0), "go", true)
    call TriggerRegisterPlayerChatEvent(gg_trg_P1_Ready_Vs_Com, Player(0), "g", true)
