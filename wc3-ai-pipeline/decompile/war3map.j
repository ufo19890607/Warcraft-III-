function InitTrig_P2_Choose takes nothing returns nothing
    set gg_trg_P2_Choose=CreateTrigger()
    call TriggerRegisterPlayerChatEvent(gg_trg_P2_Choose, Player(1), "c", true)
    call TriggerAddCondition(gg_trg_P2_Choose, Condition(function Trig_P2_Choose_Conditions))
    call TriggerAddAction(gg_trg_P2_Choose, function Trig_P2_Choose_Actions)
endfunction

