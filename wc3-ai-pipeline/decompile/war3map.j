//===========================================================================
function Trig_P2_Ready_Vs_Com_Conditions takes nothing returns boolean
    if ( not ( udg_RoundOver == false ) ) then
        return false
    endif
    if ( not ( udg_CCType == 3 ) ) then
        return false
    endif
    if ( not ( TimerGetRemaining(GetLastCreatedTimerBJ()) >= 1.00 ) ) then
        return false
    endif
    if ( not ( udg_Counting == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_Ready_Vs_Com_Func013001002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false )
