//===========================================================================
// Trigger: Computer1Evasion AI
//===========================================================================
function Trig_Computer1Evasion_AI_Func015C takes nothing returns boolean
    if ( ( GetSpellAbilityId() == 'AHtb' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'AUdc' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'AEsh' ) ) then
        return true
    endif
    return false
endfunction

function Trig_Computer1Evasion_AI_Conditions takes nothing returns boolean
    if ( not ( udg_P1Con == false ) ) then
        return false
    endif
    if ( not Trig_Computer1Evasion_AI_Func015C() ) then
        return false
    endif
    if ( not ( GetUnitStateSwap(UNIT_STATE_LIFE, GetSpellTargetUnit()) <= 300.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1Evasion_AI_Func006C takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'AHtb' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1Evasion_AI_Func007C takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'AUdc' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1Evasion_AI_Func008C takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'AEsh' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1Evasion_AI_Func009C takes nothing returns boolean
    if ( not ( UnitHasItemOfTypeBJ(GetSpellTargetUnit(), 'pams') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1Evasion_AI_Func010C takes nothing returns boolean
    if ( not ( UnitHasItemOfTypeBJ(GetSpellTargetUnit(), 'pnvl') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1Evasion_AI_Func011C takes nothing returns boolean
    if ( not ( UnitHasItemOfTypeBJ(GetSpellTargetUnit(), 'pnvu') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1Evasion_AI_Func012C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetSpellTargetUnit()) == 'Hpal' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1Evasion_AI_Func013001002 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_Computer1Evasion_AI_Func013002 takes nothing returns nothing
    call UnitUseItemTarget(GetEnumUnit(), GetItemOfTypeFromUnitBJ(GetEnumUnit(), 'spre'), GetSpellTargetUnit())
endfunction

function Trig_Computer1Evasion_AI_Actions takes nothing returns nothing
    set udg_YA=GetLocationY(GetUnitLoc(GetTriggerUnit()))
    set udg_YB=GetLocationY(GetUnitLoc(GetSpellTargetUnit()))
    set udg_XA=GetLocationX(GetUnitLoc(GetTriggerUnit()))
    set udg_XB=GetLocationX(GetUnitLoc(GetSpellTargetUnit()))
    set udg_UnitsDistance=SquareRoot(( ( ( udg_YA - udg_YB ) * ( udg_YA - udg_YB ) ) + ( ( udg_XA - udg_XB ) * ( udg_XA - udg_XB ) ) ))
    if ( Trig_Computer1Evasion_AI_Func006C() ) then
        call TriggerSleepAction(( ( ( udg_UnitsDistance / 8.94 ) + 40.00 ) / 300.00 ))
    else
    endif
    if ( Trig_Computer1Evasion_AI_Func007C() ) then
        call TriggerSleepAction(( ( ( udg_UnitsDistance / 11.31 ) + 45.20 ) / 300.00 ))
    else
    endif
    if ( Trig_Computer1Evasion_AI_Func008C() ) then
        call TriggerSleepAction(( ( ( udg_UnitsDistance / 5.13 ) + 50.00 ) / 300.00 ))
    else
    endif
    if ( Trig_Computer1Evasion_AI_Func009C() ) then
        call UnitUseItem(GetSpellTargetUnit(), GetItemOfTypeFromUnitBJ(GetSpellTargetUnit(), 'pams'))
        return
    else
    endif
    if ( Trig_Computer1Evasion_AI_Func010C() ) then
        call UnitUseItem(GetSpellTargetUnit(), GetItemOfTypeFromUnitBJ(GetSpellTargetUnit(), 'pnvl'))
        return
    else
    endif
    if ( Trig_Computer1Evasion_AI_Func011C() ) then
        call UnitUseItem(GetSpellTargetUnit(), GetItemOfTypeFromUnitBJ(GetSpellTargetUnit(), 'pnvu'))
        return
    else
    endif
    if ( Trig_Computer1Evasion_AI_Func012C() ) then
        call IssueImmediateOrderBJ(GetSpellTargetUnit(), "divineshield")
        return
    else
    endif
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_Computer1Evasion_AI_Func013001002)), function Trig_Computer1Evasion_AI_Func013002)
endfunction

//===========================================================================
function InitTrig_Computer1Evasion_AI takes nothing returns nothing
    set gg_trg_Computer1Evasion_AI=CreateTrigger()
    call TriggerRegisterPlayerUnitEventSimple(gg_trg_Computer1Evasion_AI, Player(1), EVENT_PLAYER_UNIT_SPELL_CAST)
    call TriggerAddCondition(gg_trg_Computer1Evasion_AI, Condition(function Trig_Computer1Evasion_AI_Conditions))
    call TriggerAddAction(gg_trg_Computer1Evasion_AI, function Trig_Computer1Evasion_AI_Actions)
endfunction

