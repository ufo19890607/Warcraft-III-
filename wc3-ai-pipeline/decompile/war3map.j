    return GetBooleanAnd((GetUnitTypeId(GetFilterUnit()) == 'emow'), (GetUnitManaPercent(GetFilterUnit()) > 0.00)) // INLINED!!
endfunction

function Trig_Computer2Ne_Base_Func008003001001002 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false )
endfunction

function Trig_Computer2Ne_Base_Actions takes nothing returns nothing
    call IssueImmediateOrderBJ(GetEnteringUnit(), "stop")
    call TriggerSleepAction(0.00)
    call IssueTargetOrderBJ(GetEnteringUnit(), "smart", GroupPickRandomUnit(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_Computer2Ne_Base_Func004003001002))))
    call TriggerSleepAction(6.00)
    call GroupPointOrderLocBJ(GetUnitsInRectOfPlayer(gg_rct_P2BaseArea, Player(1)), "attack", GetUnitLoc(GroupPickRandomUnit(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_Computer2Ne_Base_Func008003001001002)))))
endfunction

