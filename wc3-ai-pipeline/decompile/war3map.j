    set gg_trg_P2_Exchange_Force=CreateTrigger()
    call TriggerRegisterPlayerChatEvent(gg_trg_P2_Exchange_Force, Player(1), "s", true)
    call TriggerAddCondition(gg_trg_P2_Exchange_Force, Condition(function Trig_P2_Exchange_Force_Conditions))
