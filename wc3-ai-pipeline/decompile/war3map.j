    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('ngol')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftb')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftt')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nomg')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nogr')))
    call DestroyTimerDialogBJ(GetLastCreatedTimerDialogBJ())
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func013001002)), function Trig_P2_Ready_Vs_Com_Func013002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func014001002)), function Trig_P2_Ready_Vs_Com_Func014002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func015001002)), function Trig_P2_Ready_Vs_Com_Func015002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func016001002)), function Trig_P2_Ready_Vs_Com_Func016002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func017001002)), function Trig_P2_Ready_Vs_Com_Func017002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func018001002)), function Trig_P2_Ready_Vs_Com_Func018002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func019001002)), function Trig_P2_Ready_Vs_Com_Func019002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func020001002)), function Trig_P2_Ready_Vs_Com_Func020002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func021001002)), function Trig_P2_Ready_Vs_Com_Func021002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func022001002)), function Trig_P2_Ready_Vs_Com_Func022002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_P2_Ready_Vs_Com_Func023001002)), function Trig_P2_Ready_Vs_Com_Func023002)
    call ForGroupBJ(GetUnitsOfPlayerAll(Player(0)), function Trig_P2_Ready_Vs_Com_Func024002)
    call ForGroupBJ(GetUnitsOfPlayerAll(Player(0)), function Trig_P2_Ready_Vs_Com_Func025002)
    call TriggerSleepAction(30.00)
    call EnableTrigger(gg_trg_P1_Dust)
    call EnableTrigger(gg_trg_P2_Dust)
endfunction

