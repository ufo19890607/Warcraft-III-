function Trig_C6Round8_Actions takes nothing returns nothing
    // Player1 Force 40(31)
    // Unit:14
    call CreateNUnitsAtLoc(4, 'hmpr', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    call ForGroupBJ(GetLastCreatedGroup(), function Trig_C6Round8_Func004002)
    call CreateNUnitsAtLoc(4, 'hsor', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    call ForGroupBJ(GetLastCreatedGroup(), function Trig_C6Round8_Func006002)
    call CreateNUnitsAtLoc(8, 'hrif', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    // Hardcore
    if ( Trig_C6Round8_Func009C() ) then
        call CreateNUnitsAtLoc(2, 'hatw', udg_Race1Player, GetRectCenter(gg_rct_P2Start), bj_UNIT_FACING)
        call CreateNUnitsAtLoc(1, 'hmpr', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call ForGroupBJ(GetLastCreatedGroup(), function Trig_C6Round8_Func009Func003002)
        call CreateNUnitsAtLoc(1, 'hsor', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call ForGroupBJ(GetLastCreatedGroup(), function Trig_C6Round8_Func009Func005002)
        call CreateNUnitsAtLoc(3, 'hrif', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call CreateNUnitsAtLoc(2, 'uban', udg_Race2Player, GetPlayerStartLocationLoc(udg_Race2Player), bj_UNIT_FACING)
        call ForGroupBJ(GetLastCreatedGroup(), function Trig_C6Round8_Func009Func008002)
        // Hero:15
        // [第一英雄]
        call CreateNUnitsAtLoc(1, 'Hamg', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call SetHeroLevelBJ(GetLastCreatedUnit(), 5, false)
        if ( (GetPlayerController(udg_Race1Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
            call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
        else
            call DoNothing()
        endif
        // [Items]
        call UnitAddItemByIdSwapped('bgst', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('mnsf', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('pnvl', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('ofir', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('brac', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('pmna', GetLastCreatedUnit())
        // [第二英雄]
        call CreateNUnitsAtLoc(1, 'Hmkg', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call SetHeroLevelBJ(GetLastCreatedUnit(), 4, false)
        if ( (GetPlayerController(udg_Race1Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
            call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
        else
            call DoNothing()
        endif
        // [Items]
        call UnitAddItemByIdSwapped('pmna', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('pmna', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('brac', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('ofir', GetLastCreatedUnit())
        call ConditionalTriggerExecute(gg_trg_Race1_Secend_Hero)
        // [第三英雄]
        call CreateNUnitsAtLoc(1, 'Hpal', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call SetHeroLevelBJ(GetLastCreatedUnit(), 3, false)
        if ( (GetPlayerController(udg_Race1Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
            call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
        else
            call DoNothing()
        endif
        // [Items]
        call UnitAddItemByIdSwapped('pnvl', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('pmna', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('brac', GetLastCreatedUnit())
        call UnitAddItemByIdSwapped('ofir', GetLastCreatedUnit())
        call ConditionalTriggerExecute(gg_trg_Race1_Third_Hero)
        // ====================
    else
        // Hero:15
        // [第一英雄]
        call CreateNUnitsAtLoc(1, 'Hamg', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call SetHeroLevelBJ(GetLastCreatedUnit(), 4, false)
