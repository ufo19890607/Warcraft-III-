function InitGlobals takes nothing returns nothing
    local integer i= 0
    set udg_RoundNo=0
    set udg_RoundOver=false
    set udg_DefeatDialog=DialogCreate()
    set udg_WaitingTime=15.00
    set udg_PlayerForceFood=0
    set udg_P1Con=true
    set udg_Course=1
    set udg_CourseChooseMain=DialogCreate()
    set udg_Score1=0
    set udg_Score2=0
    set udg_win=0
    set udg_P2Con=false
    set udg_P1Race=0
    set udg_P2Race=0
    set udg_PlayerChoosing=1
    set udg_CCType=0
    set udg_TempCN=0
    set udg_Race1Player=Player(0)
    set udg_Race2Player=Player(1)
    set udg_Race1Name=""
    set udg_Race2Name=""
    set udg_TempRace=0
    set udg_Hardcore=false
    set udg_Player1Ready=false
    set udg_Player2Ready=false
    set udg_PlayerForceGroup=CreateGroup()
    set udg_RandomNumber=0
    set udg_Counting=true
    set i=0
    loop
        exitwhen ( i > 2 )
        set udg_RaceNFGroup[i]=CreateGroup()
        set i=i + 1
    endloop

    set i=0
    loop
        exitwhen ( i > 2 )
        set udg_RaceNFFood[i]=0
        set i=i + 1
    endloop

    set udg_RanI_1=0
    set udg_RanI_2=0
    set udg_RanI_3=0
    set udg_RanI_4=0
    set udg_RanI_5=0
    set udg_RanI_6=0
    set udg_Channeling=false
    set udg_Treemaking=false
    set udg_XA=0
    set udg_XB=0
    set udg_YA=0
    set udg_YB=0
    set udg_UnitsDistance=0
    set udg_Revivingtime=50.00
    set udg_TowerRush=1
    set udg_TowerRandom=0
endfunction

