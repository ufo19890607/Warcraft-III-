//===========================================================================
// Trigger: CheckPass
//===========================================================================
function Trig_CheckPass_Conditions takes nothing returns boolean
    if ( not ( udg_RoundOver == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_CheckPass_Func004001 takes nothing returns boolean
    return ( udg_win == 1 )
endfunction

function Trig_CheckPass_Func004003001 takes nothing returns boolean
    return ( udg_win == 2 )
endfunction

function Trig_CheckPass_Func005002001 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetEnumUnit()) == false )
endfunction

function Trig_CheckPass_Func005002 takes nothing returns nothing
    if ( (IsUnitAliveBJ(GetEnumUnit()) == false) ) then // INLINED!!
        call RemoveUnit(GetEnumUnit())
    else
        call DoNothing()
    endif
endfunction

function Trig_CheckPass_Func007001 takes nothing returns boolean
    return ( udg_RoundNo <= 10 )
endfunction

function Trig_CheckPass_Func007003001 takes nothing returns boolean
    return ( udg_P1Con == true )
endfunction

function Trig_CheckPass_Func007003003001 takes nothing returns boolean
    return ( udg_P2Con == true )
endfunction

function Trig_CheckPass_Actions takes nothing returns nothing
    set udg_RoundOver=true
    set udg_RoundNo=( udg_RoundNo + 1 )
    if ( (udg_win == 1) ) then // INLINED!!
        call DisplayTimedTextToForce(GetPlayersAll(), 5.00, ( GetPlayerName(Player(0)) + "获得胜利！" ))
    else
        if ( (udg_win == 2) ) then // INLINED!!
            call DisplayTimedTextToForce(GetPlayersAll(), 5.00, ( GetPlayerName(Player(1)) + "获得胜利！" ))
        else
            call DoNothing()
        endif
    endif
    call ForGroupBJ(GetUnitsInRectAll(GetPlayableMapRect()), function Trig_CheckPass_Func005002)
    call TriggerSleepAction(2.00)
    if ( (udg_RoundNo <= 10) ) then // INLINED!!
        call TriggerExecute(gg_trg_Main)
    else
        if ( (udg_P1Con == true) ) then // INLINED!!
            call DialogDisplayBJ(true, udg_DefeatDialog, Player(0))
        else
            if ( (udg_P2Con == true) ) then // INLINED!!
                call DialogDisplayBJ(true, udg_DefeatDialog, Player(1))
            else
                call TriggerExecute(gg_trg_B02)
            endif
        endif
    endif
endfunction

//===========================================================================
function InitTrig_CheckPass takes nothing returns nothing
    set gg_trg_CheckPass=CreateTrigger()
    call TriggerAddCondition(gg_trg_CheckPass, Condition(function Trig_CheckPass_Conditions))
    call TriggerAddAction(gg_trg_CheckPass, function Trig_CheckPass_Actions)
endfunction

//===========================================================================
// Trigger: TreeMaker
//===========================================================================
function Trig_TreeMaker_Func001001 takes nothing returns boolean
    return ( udg_Treemaking == true )
endfunction

function Trig_TreeMaker_Actions takes nothing returns nothing
    loop
        exitwhen ( (udg_Treemaking == true) ) // INLINED!!
        call TriggerSleepAction(RMaxBJ(bj_WAIT_FOR_COND_MIN_INTERVAL, 1))
    endloop
    call DestructableRestoreLife(GetDyingDestructable(), GetDestructableMaxLife(GetDyingDestructable()), true)
endfunction

//===========================================================================
function InitTrig_TreeMaker takes nothing returns nothing
    set gg_trg_TreeMaker=CreateTrigger()
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker1)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker2)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker3)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker4)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker5)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker6)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker7)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker8)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker9)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker10)
    call TriggerRegisterDestDeathInRegionEvent(gg_trg_TreeMaker, gg_rct_TreeMaker11)
    call TriggerAddAction(gg_trg_TreeMaker, function Trig_TreeMaker_Actions)
endfunction

