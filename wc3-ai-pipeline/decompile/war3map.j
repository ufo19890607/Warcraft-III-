function Trig_P1_Ready_Vs_Com_Actions takes nothing returns nothing
    set udg_Counting=false
    set udg_TowerRush=1
    call MeleeStartingResources()
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('ngol')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftb')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftt')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nomg')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nogr')))
    call DestroyTimerDialogBJ(GetLastCreatedTimerDialogBJ())
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func010001002)), function Trig_P1_Ready_Vs_Com_Func010002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func011001002)), function Trig_P1_Ready_Vs_Com_Func011002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func012001002)), function Trig_P1_Ready_Vs_Com_Func012002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func013001002)), function Trig_P1_Ready_Vs_Com_Func013002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func014001002)), function Trig_P1_Ready_Vs_Com_Func014002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func015001002)), function Trig_P1_Ready_Vs_Com_Func015002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func016001002)), function Trig_P1_Ready_Vs_Com_Func016002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func017001002)), function Trig_P1_Ready_Vs_Com_Func017002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func018001002)), function Trig_P1_Ready_Vs_Com_Func018002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func019001002)), function Trig_P1_Ready_Vs_Com_Func019002)
    call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_P1_Ready_Vs_Com_Func020001002)), function Trig_P1_Ready_Vs_Com_Func020002)
    call ForGroupBJ(GetUnitsOfPlayerAll(Player(1)), function Trig_P1_Ready_Vs_Com_Func021002)
    call ForGroupBJ(GetUnitsOfPlayerAll(Player(1)), function Trig_P1_Ready_Vs_Com_Func022002)
    call TriggerSleepAction(30.00)
    call EnableTrigger(gg_trg_P1_Dust)
    call EnableTrigger(gg_trg_P2_Dust)
endfunction

