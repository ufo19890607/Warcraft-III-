function Trig_C1Round1_Actions takes nothing returns nothing
    // Player1 Force 40(33)
    // Unit:23
    call CreateNUnitsAtLoc(2, 'ogru', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    call CreateNUnitsAtLoc(5, 'opeo', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    call CreateNUnitsAtLoc(2, 'orai', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    call CreateNUnitsAtLoc(2, 'ospw', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    call ForGroupBJ(GetLastCreatedGroup(), function Trig_C1Round1_Func009002)
    // Hardcore
    if ( Trig_C1Round1_Func011C() ) then
        call CreateNUnitsAtLoc(2, 'ogru', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call CreateNUnitsAtLoc(1, 'orai', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call CreateNUnitsAtLoc(1, 'ospw', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    else
        call DoNothing()
    endif
    // Hero:10
    // [第一英雄]
    call CreateNUnitsAtLoc(1, 'Obla', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    call SetHeroLevelBJ(GetLastCreatedUnit(), 2, false)
    if ( (GetPlayerController(udg_Race1Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
        call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
    else
        call DoNothing()
    endif
    // [Items]
    call UnitAddItemByIdSwapped('pnvl', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('phea', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('shea', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('bspd', GetLastCreatedUnit())
    call ConditionalTriggerExecute(gg_trg_Race1_First_Hero)
    // [第二英雄]
    call CreateNUnitsAtLoc(1, 'Otch', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
    call SetHeroLevelBJ(GetLastCreatedUnit(), 2, false)
    if ( (GetPlayerController(udg_Race1Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
        call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
    else
        call DoNothing()
    endif
    // [Items]
    call UnitAddItemByIdSwapped('shas', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('hslv', GetLastCreatedUnit())
    call ConditionalTriggerExecute(gg_trg_Race1_Secend_Hero)
    // [第三英雄]
    // [Items]
    // ====================
    // Player2 Force 40(31)
    // Unit:14
    call CreateNUnitsAtLoc(3, 'earc', udg_Race2Player, GetPlayerStartLocationLoc(udg_Race2Player), bj_UNIT_FACING)
    call CreateNUnitsAtLoc(5, 'edot', udg_Race2Player, GetPlayerStartLocationLoc(udg_Race2Player), bj_UNIT_FACING)
    call ForGroupBJ(GetLastCreatedGroup(), function Trig_C1Round1_Func038002)
    // Hardcore
    if ( Trig_C1Round1_Func040C() ) then
        call CreateNUnitsAtLoc(2, 'edot', udg_Race2Player, GetPlayerStartLocationLoc(udg_Race2Player), bj_UNIT_FACING)
    else
        call DoNothing()
    endif
    // Hero:15
    // [第一英雄]
    call CreateNUnitsAtLoc(1, 'Edem', udg_Race2Player, GetPlayerStartLocationLoc(udg_Race2Player), bj_UNIT_FACING)
    call SetHeroLevelBJ(GetLastCreatedUnit(), 2, false)
    if ( (GetPlayerController(udg_Race2Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
        call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
    else
        call DoNothing()
    endif
    // [Items]
    call UnitAddItemByIdSwapped('spre', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('phea', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('bspd', GetLastCreatedUnit())
    call UnitAddItemByIdSwapped('oven', GetLastCreatedUnit())
    call ConditionalTriggerExecute(gg_trg_Race2_First_Hero)
    // [第二英雄]
    call CreateNUnitsAtLoc(1, 'Nbst', udg_Race2Player, GetPlayerStartLocationLoc(udg_Race2Player), bj_UNIT_FACING)
    if ( (GetPlayerController(udg_Race2Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
        call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
    else
        call DoNothing()
    endif
    // [Items]
    call ConditionalTriggerExecute(gg_trg_Race2_Secend_Hero)
    call UnitAddItemByIdSwapped('shea', GetLastCreatedUnit())
    // [第三英雄]
    call CreateNUnitsAtLoc(1, 'Ntin', udg_Race2Player, GetPlayerStartLocationLoc(udg_Race2Player), bj_UNIT_FACING)
    if ( (GetPlayerController(udg_Race2Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
        call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
    else
        call DoNothing()
    endif
    // [Items]
    call ConditionalTriggerExecute(gg_trg_Race2_Third_Hero)
    // ====================
endfunction

