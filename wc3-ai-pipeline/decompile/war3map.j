    call TriggerAddCondition(gg_trg_P1_Again_Game, Condition(function Trig_P1_Again_Game_Conditions))
    call TriggerAddAction(gg_trg_P1_Again_Game, function Trig_P1_Again_Game_Actions)
endfunction

