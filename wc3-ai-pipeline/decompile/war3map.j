function Trig_Initialiaztion_Actions takes nothing returns nothing
    if ( Trig_Initialiaztion_Func002C() ) then
        set udg_CCType=1
        set udg_P1Con=true
        set udg_P2Con=true
    else
    endif
    if ( Trig_Initialiaztion_Func003C() ) then
        set udg_CCType=2
        set udg_P1Con=true
        set udg_P2Con=false
    else
    endif
    if ( Trig_Initialiaztion_Func004C() ) then
        set udg_CCType=3
        set udg_P1Con=false
        set udg_P2Con=true
    else
    endif
    if ( Trig_Initialiaztion_Func005C() ) then
        set udg_CCType=0
        set udg_P1Con=false
        set udg_P2Con=false
    else
    endif
    set udg_RoundNo=1
    set udg_Score1=0
    set udg_Score2=0
    set udg_win=0
    set udg_PlayerChoosing=1
    call SetTimeOfDay(0.00)
    call UseTimeOfDayBJ(true)
    call TriggerSleepAction(0.00)
    set udg_Race1BuildingPlace=gg_rct_P1Build
    set udg_Race2BuildingPlace=gg_rct_P2Build
    set udg_P1BasePlace=gg_rct_P1Base
    set udg_P2BasePlace=gg_rct_P2Base
    call DialogClearBJ(udg_DefeatDialog)
    call DialogAddButtonBJ(udg_DefeatDialog, "TRIGSTR_046")
    set udg_B01=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_DefeatDialog, "TRIGSTR_047")
    set udg_B02=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_DefeatDialog, "TRIGSTR_048")
    set udg_B03=GetLastCreatedButtonBJ()
    call TriggerSleepAction(0.00)
    call DialogClearBJ(udg_CourseChooseMain)
    if ( (GetBooleanOr((udg_CCType == 1), (udg_CCType == 2))) ) then // INLINED!!
        call DialogSetMessageBJ(udg_CourseChooseMain, "TRIGSTR_161")
    else
        call DoNothing()
    endif
    if ( (udg_CCType == 3) ) then // INLINED!!
        call DialogSetMessageBJ(udg_CourseChooseMain, "TRIGSTR_163")
    else
        call DoNothing()
    endif
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_040")
    set udg_CourseChoose_1=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_041")
    set udg_CourseChoose_2=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_042")
    set udg_CourseChoose_3=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_043")
    set udg_CourseChoose_4=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_044")
    set udg_CourseChoose_5=GetLastCreatedButtonBJ()
    call TriggerSleepAction(0.00)
    if ( (udg_CCType == 1) ) then // INLINED!!
        call DialogDisplayBJ(true, udg_CourseChooseMain, Player(0))
    else
        call DoNothing()
    endif
    if ( (udg_CCType == 2) ) then // INLINED!!
        call DialogDisplayBJ(true, udg_CourseChooseMain, Player(0))
    else
        call DoNothing()
    endif
    if ( (udg_CCType == 3) ) then // INLINED!!
        call DialogDisplayBJ(true, udg_CourseChooseMain, Player(1))
    else
        call DoNothing()
    endif
    if ( (udg_CCType == 0) ) then // INLINED!!
        call ConditionalTriggerExecute(gg_trg_Main)
    else
        call DoNothing()
    endif
    loop
        exitwhen ( (CountUnitsInGroup(GetUnitsInRectAll(GetPlayableMapRect())) > 5) ) // INLINED!!
        call TriggerSleepAction(RMaxBJ(bj_WAIT_FOR_COND_MIN_INTERVAL, 1))
    endloop
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_DISCOVERED, "TRIGSTR_267")
    call PlaySoundBJ(gg_snd_Hint)
    call CreateQuestBJ(bj_QUESTTYPE_REQ_DISCOVERED, "TRIGSTR_268", "TRIGSTR_269", "ReplaceableTextures\\CommandButtons\\BTNDeathCoil.blp")
    call CreateQuestItemBJ(GetLastCreatedQuestBJ(), "TRIGSTR_270")
    call CreateQuestItemBJ(GetLastCreatedQuestBJ(), "TRIGSTR_271")
    call CreateQuestItemBJ(GetLastCreatedQuestBJ(), "TRIGSTR_272")
    call CreateQuestItemBJ(GetLastCreatedQuestBJ(), "TRIGSTR_273")
    call CreateQuestItemBJ(GetLastCreatedQuestBJ(), "TRIGSTR_274")
    call CreateQuestItemBJ(GetLastCreatedQuestBJ(), "TRIGSTR_275")
    call CreateQuestItemBJ(GetLastCreatedQuestBJ(), "TRIGSTR_291")
    call CreateQuestItemBJ(GetLastCreatedQuestBJ(), "TRIGSTR_292")
    call CreateQuestBJ(bj_QUESTTYPE_REQ_DISCOVERED, "TRIGSTR_276", "TRIGSTR_277", "ReplaceableTextures\\CommandButtons\\BTNMagicalSentry.blp")
    call CreateQuestBJ(bj_QUESTTYPE_OPT_DISCOVERED, "TRIGSTR_302", "TRIGSTR_303", "ReplaceableTextures\\CommandButtons\\BTNDevotion.blp")
    call CreateQuestBJ(bj_QUESTTYPE_OPT_DISCOVERED, "TRIGSTR_304", "TRIGSTR_305", "ReplaceableTextures\\CommandButtons\\BTNDoom.blp")
    call CreateQuestBJ(bj_QUESTTYPE_OPT_DISCOVERED, "TRIGSTR_310", "TRIGSTR_311", "ReplaceableTextures\\CommandButtons\\BTNHeroCryptLord.blp")
    call CreateQuestBJ(bj_QUESTTYPE_OPT_DISCOVERED, "TRIGSTR_278", "TRIGSTR_279", "ReplaceableTextures\\CommandButtons\\BTNBrilliance.blp")
    call CreateQuestBJ(bj_QUESTTYPE_OPT_DISCOVERED, "TRIGSTR_312", "TRIGSTR_313", "ReplaceableTextures\\CommandButtons\\BTNDustOfAppearance.blp")
    call CreateQuestBJ(bj_QUESTTYPE_OPT_DISCOVERED, "TRIGSTR_308", "TRIGSTR_309", "ReplaceableTextures\\CommandButtons\\BTNThoriumMelee.blp")
    call TriggerSleepAction(4.00)
    call QuestMessageBJ(GetPlayersAll(), bj_QUESTMESSAGE_SECRET, "TRIGSTR_290")
endfunction

//===========================================================================
function InitTrig_Initialiaztion takes nothing returns nothing
    set gg_trg_Initialiaztion=CreateTrigger()
    call TriggerAddAction(gg_trg_Initialiaztion, function Trig_Initialiaztion_Actions)
endfunction

