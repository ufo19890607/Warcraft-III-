//===========================================================================
function Trig_B03_Conditions takes nothing returns boolean
    if ( not ( GetClickedButtonBJ() == udg_B03 ) ) then
        return false
    endif
    return true
endfunction

function Trig_B03_Func001001 takes nothing returns boolean
    return ( udg_Score1 > udg_Score2 )
endfunction

function Trig_B03_Func001003001 takes nothing returns boolean
    return ( udg_Score1 <= udg_Score2 )
endfunction

function Trig_B03_Actions takes nothing returns nothing
    if ( (udg_Score1 > udg_Score2) ) then // INLINED!!
        call CustomVictoryBJ(Player(0), true, true)
    else
        if ( (udg_Score1 <= udg_Score2) ) then // INLINED!!
            call CustomVictoryBJ(Player(1), true, true)
        else
            call DoNothing()
        endif
    endif
    call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_067")
endfunction

//===========================================================================
function InitTrig_B03 takes nothing returns nothing
    set gg_trg_B03=CreateTrigger()
    call TriggerRegisterDialogEventBJ(gg_trg_B03, udg_DefeatDialog)
    call TriggerAddCondition(gg_trg_B03, Condition(function Trig_B03_Conditions))
    call TriggerAddAction(gg_trg_B03, function Trig_B03_Actions)
endfunction

