//===========================================================================
// Trigger: Player1Win
//===========================================================================
function Trig_Player1Win_Func005001001002001 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_Player1Win_Func005001001002002 takes nothing returns boolean
    return ( IsUnitIdType(GetUnitTypeId(GetFilterUnit()), UNIT_TYPE_STRUCTURE) == false )
endfunction

function Trig_Player1Win_Func005001001002 takes nothing returns boolean
    return GetBooleanAnd((IsUnitAliveBJ(GetFilterUnit()) == true), (IsUnitIdType(GetUnitTypeId(GetFilterUnit()), UNIT_TYPE_STRUCTURE) == false)) // INLINED!!
endfunction

function Trig_Player1Win_Conditions takes nothing returns boolean
    if ( not ( udg_RoundOver == false ) ) then
        return false
    endif
    if ( not ( CountUnitsInGroup(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_Player1Win_Func005001001002))) <= 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Player1Win_Actions takes nothing returns nothing
    set udg_Score1=( udg_Score1 + 1 )
    set udg_win=1
    call ConditionalTriggerExecute(gg_trg_CheckPass)
endfunction

//===========================================================================
function InitTrig_Player1Win takes nothing returns nothing
    set gg_trg_Player1Win=CreateTrigger()
    call TriggerRegisterPlayerUnitEventSimple(gg_trg_Player1Win, Player(1), EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_Player1Win, Condition(function Trig_Player1Win_Conditions))
    call TriggerAddAction(gg_trg_Player1Win, function Trig_Player1Win_Actions)
endfunction

