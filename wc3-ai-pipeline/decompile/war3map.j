    set udg_PlayerForceGroup=GetUnitsOfPlayerAll(udg_Race2Player)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=CountUnitsInGroup(udg_PlayerForceGroup)
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_PlayerForceUnit=GroupPickRandomUnit(udg_PlayerForceGroup)
        set udg_PlayerForceFood=( udg_PlayerForceFood + GetUnitFoodUsed(udg_PlayerForceUnit) )
        call GroupRemoveUnitSimple(udg_PlayerForceUnit, udg_PlayerForceGroup)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    if ( Trig_NeCoureF1_1_10_Func004C() ) then
        call CreateNUnitsAtLoc(3, 'emow', udg_Race2Player, GetRectCenter(gg_rct_MoonWell), bj_UNIT_FACING)
        call ForGroupBJ(GetLastCreatedGroup(), function Trig_NeCoureF1_1_10_Func004Func004002)
    else
        call DoNothing()
    endif
    if ( Trig_NeCoureF1_1_10_Func005C() ) then
        call CreateNUnitsAtLoc(3, 'emow', udg_Race2Player, GetRectCenter(gg_rct_MoonWell), bj_UNIT_FACING)
        call ForGroupBJ(GetLastCreatedGroup(), function Trig_NeCoureF1_1_10_Func005Func004002)
