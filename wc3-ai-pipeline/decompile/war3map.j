    call TriggerAddCondition(gg_trg_Computer1StopAttack, Condition(function Trig_Computer1StopAttack_Conditions))
    call TriggerAddAction(gg_trg_Computer1StopAttack, function Trig_Computer1StopAttack_Actions)
endfunction

