function Trig_P2_Exchange_Force_Actions takes nothing returns nothing
    set udg_RoundOver=true
    set udg_RoundNo=udg_RoundNo
    set udg_TempPlayer=udg_Race1Player
    set udg_Race1Player=udg_Race2Player
    set udg_Race2Player=udg_TempPlayer
    set udg_TempRace=udg_P1Race
    set udg_P1Race=udg_P2Race
    set udg_P2Race=udg_TempRace
    set udg_TempPlace=udg_Race1BuildingPlace
    set udg_Race1BuildingPlace=udg_Race2BuildingPlace
    set udg_Race2BuildingPlace=udg_TempPlace
    call TriggerSleepAction(0.01)
    set udg_TempPlace=udg_P1BasePlace
    set udg_P1BasePlace=udg_P2BasePlace
    set udg_P2BasePlace=udg_TempPlace
    if ( (udg_P1Race == 1) ) then // INLINED!!
        set udg_Race1Name="H"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 2) ) then // INLINED!!
        set udg_Race1Name="O"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 3) ) then // INLINED!!
        set udg_Race1Name="U"
    else
        call DoNothing()
    endif
    if ( (udg_P1Race == 4) ) then // INLINED!!
        set udg_Race1Name="N"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 1) ) then // INLINED!!
        set udg_Race2Name="H"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 2) ) then // INLINED!!
        set udg_Race2Name="O"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 3) ) then // INLINED!!
        set udg_Race2Name="U"
    else
        call DoNothing()
    endif
    if ( (udg_P2Race == 4) ) then // INLINED!!
        set udg_Race2Name="N"
    else
        call DoNothing()
    endif
    call TriggerExecute(gg_trg_Research)
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('ngol')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftb')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftt')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nomg')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nogr')))
    call TriggerSleepAction(0.01)
    call TriggerExecute(gg_trg_Main)
endfunction

