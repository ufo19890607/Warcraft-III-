//===========================================================================
// Trigger: P1 Ready
//===========================================================================
function Trig_P1_Ready_Conditions takes nothing returns boolean
    if ( not ( udg_RoundOver == false ) ) then
        return false
    endif
    if ( not ( udg_CCType == 1 ) ) then
        return false
    endif
    if ( not ( udg_Player1Ready == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_P1_Ready_Actions takes nothing returns nothing
    set udg_Player1Ready=true
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('ngol')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftb')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftt')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nomg')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nogr')))
endfunction

//===========================================================================
function InitTrig_P1_Ready takes nothing returns nothing
    set gg_trg_P1_Ready=CreateTrigger()
    call TriggerRegisterPlayerChatEvent(gg_trg_P1_Ready, Player(0), "ready", true)
    call TriggerRegisterPlayerChatEvent(gg_trg_P1_Ready, Player(0), "go", true)
    call TriggerRegisterPlayerChatEvent(gg_trg_P1_Ready, Player(0), "ok", true)
    call TriggerRegisterPlayerChatEvent(gg_trg_P1_Ready, Player(0), "k", true)
    call TriggerRegisterPlayerChatEvent(gg_trg_P1_Ready, Player(0), "g", true)
    call TriggerAddCondition(gg_trg_P1_Ready, Condition(function Trig_P1_Ready_Conditions))
    call TriggerAddAction(gg_trg_P1_Ready, function Trig_P1_Ready_Actions)
endfunction

//===========================================================================
// Trigger: P1 Ready Vs Com
//===========================================================================
function Trig_P1_Ready_Vs_Com_Conditions takes nothing returns boolean
    if ( not ( udg_RoundOver == false ) ) then
        return false
    endif
    if ( not ( udg_CCType == 2 ) ) then
        return false
    endif
    if ( not ( TimerGetRemaining(GetLastCreatedTimerBJ()) >= 1.00 ) ) then
        return false
    endif
    if ( not ( udg_Counting == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_P1_Ready_Vs_Com_Func010001002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false )
endfunction

function Trig_P1_Ready_Vs_Com_Func010001002002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == false )
endfunction

function Trig_P1_Ready_Vs_Com_Func010001002002002 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_RANGED_ATTACKER) == true )
endfunction

function Trig_P1_Ready_Vs_Com_Func010001002002 takes nothing returns boolean
    return GetBooleanAnd((IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == false), (IsUnitType(GetFilterUnit(), UNIT_TYPE_RANGED_ATTACKER) == true)) // INLINED!!
endfunction

function Trig_P1_Ready_Vs_Com_Func010001002 takes nothing returns boolean
    return GetBooleanAnd((IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false), (GetBooleanAnd((IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == false), (IsUnitType(GetFilterUnit(), UNIT_TYPE_RANGED_ATTACKER) == true)))) // INLINED!!
endfunction

function Trig_P1_Ready_Vs_Com_Func010002 takes nothing returns nothing
    call SetUnitPositionLoc(GetEnumUnit(), GetRectCenter(gg_rct_P2Start))
endfunction

