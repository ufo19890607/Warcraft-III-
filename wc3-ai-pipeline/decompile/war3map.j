function Trig_ComputerForceCountdown_Actions takes nothing returns nothing
    set udg_PlayerForceGroup=GetUnitsOfPlayerAll(ForcePickRandomPlayer(GetPlayersMatching(Condition(function Trig_ComputerForceCountdown_Func001002001001001))))
    set udg_TowerRush=1
    call MeleeStartingResources()
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('ngol')))
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=CountUnitsInGroup(udg_PlayerForceGroup)
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_PlayerForceUnit=GroupPickRandomUnit(udg_PlayerForceGroup)
        set udg_PlayerForceFood=( udg_PlayerForceFood + GetUnitFoodUsed(udg_PlayerForceUnit) )
        call GroupRemoveUnitSimple(udg_PlayerForceUnit, udg_PlayerForceGroup)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    if ( (GetBooleanAnd((udg_PlayerForceFood > 0), (udg_PlayerForceFood <= 40))) ) then // INLINED!!
        set udg_WaitingTime=10.00
    else
        call DoNothing()
    endif
    if ( (GetBooleanAnd((udg_PlayerForceFood > 40), (udg_PlayerForceFood <= 50))) ) then // INLINED!!
        set udg_WaitingTime=15.00
    else
        call DoNothing()
    endif
    if ( (GetBooleanAnd((udg_PlayerForceFood > 50), (udg_PlayerForceFood <= 100))) ) then // INLINED!!
        set udg_WaitingTime=30.00
    else
        call DoNothing()
    endif
    if ( (GetBooleanAnd((udg_PlayerForceFood > 100), (udg_PlayerForceFood <= 130))) ) then // INLINED!!
        set udg_WaitingTime=45.00
    else
        call DoNothing()
    endif
    if ( (GetBooleanAnd((udg_PlayerForceFood > 130), (udg_PlayerForceFood <= 200))) ) then // INLINED!!
        set udg_WaitingTime=55.00
    else
        call DoNothing()
    endif
    set udg_Counting=true
    if ( Trig_ComputerForceCountdown_Func012C() ) then
        call ForGroupBJ(GetUnitsOfPlayerAll(Player(1)), function Trig_ComputerForceCountdown_Func012Func002002)
        call ForGroupBJ(GetUnitsOfPlayerAll(Player(1)), function Trig_ComputerForceCountdown_Func012Func003002)
        call DestroyTimerDialogBJ(GetLastCreatedTimerDialogBJ())
        call CreateTimerDialogBJ(GetLastCreatedTimerBJ(), "TRIGSTR_215")
        call StartTimerBJ(GetLastCreatedTimerBJ(), false, udg_WaitingTime)
        call TriggerSleepAction(( udg_WaitingTime + 0.30 ))
        if ( Trig_ComputerForceCountdown_Func012Func008C() ) then
            call DestroyTimerDialogBJ(GetLastCreatedTimerDialogBJ())
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func002001002)), function Trig_ComputerForceCountdown_Func012Func008Func002002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func003001002)), function Trig_ComputerForceCountdown_Func012Func008Func003002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func004001002)), function Trig_ComputerForceCountdown_Func012Func008Func004002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func005001002)), function Trig_ComputerForceCountdown_Func012Func008Func005002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func006001002)), function Trig_ComputerForceCountdown_Func012Func008Func006002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func007001002)), function Trig_ComputerForceCountdown_Func012Func008Func007002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func008001002)), function Trig_ComputerForceCountdown_Func012Func008Func008002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func009001002)), function Trig_ComputerForceCountdown_Func012Func008Func009002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func010001002)), function Trig_ComputerForceCountdown_Func012Func008Func010002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func011001002)), function Trig_ComputerForceCountdown_Func012Func008Func011002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(1), Condition(function Trig_ComputerForceCountdown_Func012Func008Func012001002)), function Trig_ComputerForceCountdown_Func012Func008Func012002)
            call ForGroupBJ(GetUnitsOfPlayerAll(Player(1)), function Trig_ComputerForceCountdown_Func012Func008Func013002)
            call ForGroupBJ(GetUnitsOfPlayerAll(Player(1)), function Trig_ComputerForceCountdown_Func012Func008Func014002)
            set udg_Counting=false
            call TriggerSleepAction(30.00)
            call EnableTrigger(gg_trg_P1_Dust)
            call EnableTrigger(gg_trg_P2_Dust)
        else
            call DoNothing()
        endif
    else
        call DoNothing()
    endif
    if ( Trig_ComputerForceCountdown_Func013C() ) then
        call ForGroupBJ(GetUnitsOfPlayerAll(Player(0)), function Trig_ComputerForceCountdown_Func013Func001002)
        call ForGroupBJ(GetUnitsOfPlayerAll(Player(0)), function Trig_ComputerForceCountdown_Func013Func002002)
        call DestroyTimerDialogBJ(GetLastCreatedTimerDialogBJ())
        call CreateTimerDialogBJ(GetLastCreatedTimerBJ(), "TRIGSTR_216")
        call StartTimerBJ(GetLastCreatedTimerBJ(), false, udg_WaitingTime)
        call TriggerSleepAction(( udg_WaitingTime + 0.30 ))
        if ( Trig_ComputerForceCountdown_Func013Func007C() ) then
            call DestroyTimerDialogBJ(GetLastCreatedTimerDialogBJ())
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func004001002)), function Trig_ComputerForceCountdown_Func013Func007Func004002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func005001002)), function Trig_ComputerForceCountdown_Func013Func007Func005002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func006001002)), function Trig_ComputerForceCountdown_Func013Func007Func006002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func007001002)), function Trig_ComputerForceCountdown_Func013Func007Func007002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func008001002)), function Trig_ComputerForceCountdown_Func013Func007Func008002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func009001002)), function Trig_ComputerForceCountdown_Func013Func007Func009002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func010001002)), function Trig_ComputerForceCountdown_Func013Func007Func010002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func011001002)), function Trig_ComputerForceCountdown_Func013Func007Func011002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func012001002)), function Trig_ComputerForceCountdown_Func013Func007Func012002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func013001002)), function Trig_ComputerForceCountdown_Func013Func007Func013002)
            call ForGroupBJ(GetUnitsOfPlayerMatching(Player(0), Condition(function Trig_ComputerForceCountdown_Func013Func007Func014001002)), function Trig_ComputerForceCountdown_Func013Func007Func014002)
            call ForGroupBJ(GetUnitsOfPlayerAll(Player(0)), function Trig_ComputerForceCountdown_Func013Func007Func015002)
            call ForGroupBJ(GetUnitsOfPlayerAll(Player(0)), function Trig_ComputerForceCountdown_Func013Func007Func016002)
            set udg_Counting=false
            call TriggerSleepAction(30.00)
            call EnableTrigger(gg_trg_P1_Dust)
            call EnableTrigger(gg_trg_P2_Dust)
        else
            call DoNothing()
        endif
    else
    endif
endfunction

