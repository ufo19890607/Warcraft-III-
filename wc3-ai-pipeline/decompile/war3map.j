function Trig_CCbuttons_Actions takes nothing returns nothing
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_175")
    set udg_CourseChoose_1=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_176")
    set udg_CourseChoose_2=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_177")
    set udg_CourseChoose_3=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_178")
    set udg_CourseChoose_4=GetLastCreatedButtonBJ()
    call DialogAddButtonBJ(udg_CourseChooseMain, "TRIGSTR_179")
    set udg_CourseChoose_5=GetLastCreatedButtonBJ()
endfunction

//===========================================================================
function InitTrig_CCbuttons takes nothing returns nothing
    set gg_trg_CCbuttons=CreateTrigger()
    call TriggerAddAction(gg_trg_CCbuttons, function Trig_CCbuttons_Actions)
endfunction

//===========================================================================
// Trigger: CC1
//===========================================================================
function Trig_CC1_Conditions takes nothing returns boolean
    if ( not ( GetClickedButtonBJ() == udg_CourseChoose_1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CC1_Func001Func005001001 takes nothing returns boolean
    return ( udg_CCType == 1 )
endfunction

function Trig_CC1_Func001Func005001002 takes nothing returns boolean
    return ( udg_CCType == 3 )
endfunction

function Trig_CC1_Func001Func005001 takes nothing returns boolean
    return GetBooleanOr((udg_CCType == 1), (udg_CCType == 3)) // INLINED!!
endfunction

function Trig_CC1_Func001Func006001 takes nothing returns boolean
    return ( udg_CCType == 2 )
endfunction

function Trig_CC1_Func001Func009001 takes nothing returns boolean
    return ( udg_CCType == 1 )
endfunction

function Trig_CC1_Func001Func010001 takes nothing returns boolean
    return ( udg_CCType == 2 )
endfunction

function Trig_CC1_Func001Func011001 takes nothing returns boolean
    return ( udg_CCType == 3 )
endfunction

function Trig_CC1_Func001C takes nothing returns boolean
    if ( not ( udg_PlayerChoosing == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CC1_Func002C takes nothing returns boolean
    if ( not ( udg_PlayerChoosing == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CC1_Actions takes nothing returns nothing
    if ( Trig_CC1_Func001C() ) then
        set udg_P1Race=0
        set udg_PlayerChoosing=( udg_PlayerChoosing + 1 )
        call TriggerSleepAction(0.00)
        call DialogClearBJ(udg_CourseChooseMain)
        if ( (GetBooleanOr((udg_CCType == 1), (udg_CCType == 3))) ) then // INLINED!!
            call DialogSetMessageBJ(udg_CourseChooseMain, "TRIGSTR_190")
        else
            call DoNothing()
        endif
        if ( (udg_CCType == 2) ) then // INLINED!!
            call DialogSetMessageBJ(udg_CourseChooseMain, "TRIGSTR_191")
        else
            call DoNothing()
        endif
        call TriggerExecute(gg_trg_CCbuttons)
        call TriggerSleepAction(0.00)
        if ( (udg_CCType == 1) ) then // INLINED!!
            call DialogDisplayBJ(true, udg_CourseChooseMain, Player(1))
        else
            call DoNothing()
        endif
        if ( (udg_CCType == 2) ) then // INLINED!!
            call DialogDisplayBJ(true, udg_CourseChooseMain, Player(0))
        else
            call DoNothing()
        endif
        if ( (udg_CCType == 3) ) then // INLINED!!
            call DialogDisplayBJ(true, udg_CourseChooseMain, Player(1))
        else
            call DoNothing()
        endif
        return
    else
    endif
    if ( Trig_CC1_Func002C() ) then
        set udg_PlayerChoosing=1
        set udg_P2Race=0
        call ConditionalTriggerExecute(gg_trg_CourseName)
        call TriggerSleepAction(0.01)
    else
        call DoNothing()
    endif
    call TriggerSleepAction(0.01)
    set udg_RoundNo=1
    set udg_Score1=0
    set udg_Score2=0
    call TriggerExecute(gg_trg_Main)
endfunction

//===========================================================================
function InitTrig_CC1 takes nothing returns nothing
    set gg_trg_CC1=CreateTrigger()
    call TriggerRegisterDialogEventBJ(gg_trg_CC1, udg_CourseChooseMain)
    call TriggerAddCondition(gg_trg_CC1, Condition(function Trig_CC1_Conditions))
    call TriggerAddAction(gg_trg_CC1, function Trig_CC1_Actions)
endfunction

