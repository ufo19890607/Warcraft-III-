        call UnitAddItemByIdSwapped('ofir', GetLastCreatedUnit())
        call ConditionalTriggerExecute(gg_trg_Race1_First_Hero)
        // [第二英雄]
        call CreateNUnitsAtLoc(1, 'Hmkg', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call SetHeroLevelBJ(GetLastCreatedUnit(), 3, false)
        if ( (GetPlayerController(udg_Race1Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
            call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
        else
            call DoNothing()
        endif
        // [Items]
        call UnitAddItemByIdSwapped('pmna', GetLastCreatedUnit())
        call ConditionalTriggerExecute(gg_trg_Race1_Secend_Hero)
        // [第三英雄]
        call CreateNUnitsAtLoc(1, 'Hpal', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call SetHeroLevelBJ(GetLastCreatedUnit(), 2, false)
        if ( (GetPlayerController(udg_Race1Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
