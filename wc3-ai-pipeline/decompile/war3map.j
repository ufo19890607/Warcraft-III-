    return ( IsUnitAliveBJ(GetEnumUnit()) == false )
endfunction

function Trig_P2_Again_Game_Func007002 takes nothing returns nothing
    if ( (IsUnitAliveBJ(GetEnumUnit()) == false) ) then // INLINED!!
        call RemoveUnit(GetEnumUnit())
    else
        call DoNothing()
    endif
endfunction

function Trig_P2_Again_Game_Actions takes nothing returns nothing
    set udg_RoundOver=true
    set udg_Score1=( udg_Score1 + 1 )
    set udg_win=2
    set udg_RoundNo=udg_RoundNo
    if ( (udg_win == 1) ) then // INLINED!!
        call DisplayTimedTextToForce(GetPlayersAll(), 5.00, ( GetPlayerName(Player(0)) + "获得胜利！" ))
    else
        if ( (udg_win == 2) ) then // INLINED!!
            call DisplayTimedTextToForce(GetPlayersAll(), 5.00, ( GetPlayerName(Player(1)) + "获得胜利！" ))
        else
            call DoNothing()
        endif
    endif
    call ForGroupBJ(GetUnitsInRectAll(GetPlayableMapRect()), function Trig_P2_Again_Game_Func007002)
    call TriggerSleepAction(2.00)
    call TriggerExecute(gg_trg_Main)
endfunction

