    call TriggerAddCondition(gg_trg_Computer2Ne_Base, Condition(function Trig_Computer2Ne_Base_Conditions))
    call TriggerAddAction(gg_trg_Computer2Ne_Base, function Trig_Computer2Ne_Base_Actions)
endfunction

//===========================================================================
// Trigger: Computer1StopAttack
//===========================================================================
function Trig_Computer1StopAttack_Func007C takes nothing returns boolean
    if ( ( GetSpellAbilityId() == 'ANrf' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'AHbz' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'AHfs' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'AHdr' ) ) then
        return true
    endif
    return false
endfunction

function Trig_Computer1StopAttack_Conditions takes nothing returns boolean
    if ( not ( GetPlayerController(Player(0)) == MAP_CONTROL_COMPUTER ) ) then
        return false
    endif
    if ( not Trig_Computer1StopAttack_Func007C() ) then
        return false
    endif
    return true
endfunction

function Trig_Computer1StopAttack_Func004001001 takes nothing returns boolean
    return ( udg_RoundOver == true )
endfunction

function Trig_Computer1StopAttack_Func004001002 takes nothing returns boolean
    return ( udg_Channeling == false )
endfunction

function Trig_Computer1StopAttack_Func004001 takes nothing returns boolean
    return GetBooleanOr((udg_RoundOver == true), (udg_Channeling == false)) // INLINED!!
endfunction

function Trig_Computer1StopAttack_Actions takes nothing returns nothing
    set udg_Channeling=true
    call DisableTrigger(gg_trg_Computer1Combat_AI)
    call TriggerSleepAction(1.00)
    loop
        exitwhen ( (GetBooleanOr((udg_RoundOver == true), (udg_Channeling == false))) ) // INLINED!!
        call TriggerSleepAction(RMaxBJ(bj_WAIT_FOR_COND_MIN_INTERVAL, 1))
    endloop
    call EnableTrigger(gg_trg_Computer1Combat_AI)
endfunction

