function Trig_HumCoureF2_6_8_Actions takes nothing returns nothing
    if ( Trig_HumCoureF2_6_8_Func001C() ) then
        call CreateNUnitsAtLoc(1, 'hfoo', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call CreateNUnitsAtLoc(3, 'hmil', udg_Race1Player, GetRectCenter(gg_rct_P2Start), bj_UNIT_FACING)
    else
        call CreateNUnitsAtLoc(3, 'hmil', udg_Race1Player, GetRectCenter(gg_rct_P2Start), bj_UNIT_FACING)
    endif
    if ( Trig_HumCoureF2_6_8_Func002C() ) then
        set udg_TowerRush=2
    else
        call RemoveUnit(GroupPickRandomUnit(GetUnitsOfPlayerAndTypeId(udg_Race1Player, 'Nfir')))
        call CreateNUnitsAtLoc(1, 'Nfir', udg_Race1Player, GetPlayerStartLocationLoc(udg_Race1Player), bj_UNIT_FACING)
        call SetHeroLevelBJ(GetLastCreatedUnit(), 1, false)
        if ( (GetPlayerController(udg_Race1Player) == MAP_CONTROL_COMPUTER) ) then // INLINED!!
            call ConditionalTriggerExecute(gg_trg_ComputerSkill1)
        else
            call DoNothing()
        endif
        call ForGroupBJ(GetLastCreatedGroup(), function Trig_HumCoureF2_6_8_Func002Func005002)
        set udg_TowerRandom=GetRandomInt(1, 2)
        if ( Trig_HumCoureF2_6_8_Func002Func007C() ) then
            call CreateNUnitsAtLoc(1, 'hatw', udg_Race1Player, GetRectCenter(gg_rct_TowerArea2), bj_UNIT_FACING)
        else
            call CreateNUnitsAtLoc(1, 'hgtw', udg_Race1Player, GetRectCenter(gg_rct_TowerArea1), bj_UNIT_FACING)
        endif
    endif
endfunction

