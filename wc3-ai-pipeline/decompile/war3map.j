//===========================================================================
function Trig_P2_Choose_Conditions takes nothing returns boolean
    if ( not ( udg_RoundOver == false ) ) then
        return false
    endif
    if ( not ( udg_P1Con == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_Choose_Func005001001 takes nothing returns boolean
    return ( udg_CCType == 1 )
endfunction

function Trig_P2_Choose_Func005001002 takes nothing returns boolean
    return ( udg_CCType == 2 )
endfunction

function Trig_P2_Choose_Func005001 takes nothing returns boolean
    return GetBooleanOr((udg_CCType == 1), (udg_CCType == 2)) // INLINED!!
endfunction

function Trig_P2_Choose_Func006001 takes nothing returns boolean
    return ( udg_CCType == 3 )
endfunction

function Trig_P2_Choose_Func014001 takes nothing returns boolean
    return ( udg_CCType == 1 )
endfunction

function Trig_P2_Choose_Func015001 takes nothing returns boolean
    return ( udg_CCType == 2 )
endfunction

function Trig_P2_Choose_Func016001 takes nothing returns boolean
    return ( udg_CCType == 3 )
endfunction

function Trig_P2_Choose_Actions takes nothing returns nothing
    call PauseGameOn()
    set udg_RoundOver=true
    call TriggerSleepAction(0.00)
    call DialogClearBJ(udg_CourseChooseMain)
    if ( (GetBooleanOr((udg_CCType == 1), (udg_CCType == 2))) ) then // INLINED!!
        call DialogSetMessageBJ(udg_CourseChooseMain, "TRIGSTR_196")
    else
        call DoNothing()
    endif
    if ( (udg_CCType == 3) ) then // INLINED!!
        call DialogSetMessageBJ(udg_CourseChooseMain, "TRIGSTR_197")
    else
        call DoNothing()
    endif
    call TriggerSleepAction(0.00)
    call TriggerExecute(gg_trg_CCbuttons)
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('ngol')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftb')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nftt')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nomg')))
    call RemoveUnit(GroupPickRandomUnit(GetUnitsOfTypeIdAll('nogr')))
    if ( (udg_CCType == 1) ) then // INLINED!!
        call DialogDisplayBJ(true, udg_CourseChooseMain, Player(0))
    else
        call DoNothing()
    endif
    if ( (udg_CCType == 2) ) then // INLINED!!
        call DialogDisplayBJ(true, udg_CourseChooseMain, Player(0))
    else
        call DoNothing()
    endif
    if ( (udg_CCType == 3) ) then // INLINED!!
        call DialogDisplayBJ(true, udg_CourseChooseMain, Player(1))
    else
        call DoNothing()
    endif
endfunction

