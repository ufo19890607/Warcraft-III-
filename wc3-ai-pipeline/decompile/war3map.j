function Trig_Main_Actions takes nothing returns nothing
    // Round Initialization
    call PauseGameOff()
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=2
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call ForGroupBJ(GetUnitsOfPlayerAll(ConvertedPlayer(GetForLoopIndexA())), function Trig_Main_Func003003002)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call ForGroupBJ(GetUnitsOfTypeIdAll('nshe'), function Trig_Main_Func004002)
    call EnumItemsInRectBJ(GetPlayableMapRect(), function Trig_Main_Func005002)
    set udg_Treemaking=true
    call ResetToGameCameraForPlayer(Player(0), 0)
    call ResetToGameCameraForPlayer(Player(1), 0)
    call PanCameraToTimedLocForPlayer(Player(0), GetPlayerStartLocationLoc(Player(0)), 0.50)
    call PanCameraToTimedLocForPlayer(Player(1), GetPlayerStartLocationLoc(Player(1)), 0.50)
    call EnableTrigger(gg_trg_Computer1Combat_AI)
    call EnableTrigger(gg_trg_Computer2Combat_AI)
    call DisableTrigger(gg_trg_P1_Dust)
    call DisableTrigger(gg_trg_P2_Dust)
    call FogEnableOn()
    call FogMaskEnableOn()
    call DisplayTimedTextToForce(GetPlayersAll(), 2.00, ( ( "第" + I2S(udg_RoundNo) ) + "关开始" ))
    // Variable Reset
    set udg_RoundOver=false
    set udg_Player1Ready=false
    set udg_Player2Ready=false
    set udg_PlayerForceFood=0
    set udg_RandomNumber=0
    set udg_Counting=false
    set udg_Channeling=false
    // LeaderBoard
    if ( Trig_Main_Func027C() ) then
        call CreateLeaderboardBJ(GetPlayersAll(), ( ( ( udg_Race1Name + ( "v" + udg_Race2Name ) ) + "  第 " ) + ( I2S(udg_RoundNo) + " 关" ) ))
    else
        call DoNothing()
    endif
    if ( Trig_Main_Func028C() ) then
        call CreateLeaderboardBJ(GetPlayersAll(), ( ( ( ( "简单 " + udg_Race1Name ) + ( "v" + udg_Race2Name ) ) + "  第 " ) + ( I2S(udg_RoundNo) + " 关" ) ))
    else
        call DoNothing()
    endif
    if ( Trig_Main_Func029C() ) then
        call CreateLeaderboardBJ(GetPlayersAll(), ( ( ( ( "困难 " + udg_Race1Name ) + ( "v" + udg_Race2Name ) ) + "  第 " ) + ( I2S(udg_RoundNo) + " 关" ) ))
    else
        call DoNothing()
    endif
    call LeaderboardAddItemBJ(Player(0), GetLastCreatedLeaderboard(), GetPlayerName(Player(0)), udg_Score1)
    call LeaderboardAddItemBJ(Player(1), GetLastCreatedLeaderboard(), GetPlayerName(Player(1)), udg_Score2)
    call LeaderboardDisplayBJ(true, GetLastCreatedLeaderboard())
    // Run Round
    if ( Trig_Main_Func034C() ) then
        call ConditionalTriggerExecute(gg_trg_C1Round1)
        call ConditionalTriggerExecute(gg_trg_C1Round2)
        call ConditionalTriggerExecute(gg_trg_C1Round3)
        call ConditionalTriggerExecute(gg_trg_C1Round4)
        call ConditionalTriggerExecute(gg_trg_C1Round5)
        call ConditionalTriggerExecute(gg_trg_C1Round6)
        call ConditionalTriggerExecute(gg_trg_C1Round7)
        call ConditionalTriggerExecute(gg_trg_C1Round8)
        call ConditionalTriggerExecute(gg_trg_C1Round9)
        call ConditionalTriggerExecute(gg_trg_C1Round10)
    else
    endif
    if ( Trig_Main_Func035C() ) then
        call ConditionalTriggerExecute(gg_trg_C2Round1)
        call ConditionalTriggerExecute(gg_trg_C2Round2)
        call ConditionalTriggerExecute(gg_trg_C2Round3)
        call ConditionalTriggerExecute(gg_trg_C2Round4)
        call ConditionalTriggerExecute(gg_trg_C2Round5)
        call ConditionalTriggerExecute(gg_trg_C2Round6)
        call ConditionalTriggerExecute(gg_trg_C2Round7_RH_Hm)
        call ConditionalTriggerExecute(gg_trg_C2Round8_Hm)
        call ConditionalTriggerExecute(gg_trg_C2Round9_Hm)
        call ConditionalTriggerExecute(gg_trg_C2Round10)
    else
    endif
    if ( Trig_Main_Func036C() ) then
        call ConditionalTriggerExecute(gg_trg_C3Round1)
        call ConditionalTriggerExecute(gg_trg_C3Round2)
        call ConditionalTriggerExecute(gg_trg_C3Round3)
        call ConditionalTriggerExecute(gg_trg_C3Round4)
        call ConditionalTriggerExecute(gg_trg_C3Round5_RH)
        call ConditionalTriggerExecute(gg_trg_C3Round6_RH)
        call ConditionalTriggerExecute(gg_trg_C3Round7)
        call ConditionalTriggerExecute(gg_trg_C3Round8)
        call ConditionalTriggerExecute(gg_trg_C3Round9)
        call ConditionalTriggerExecute(gg_trg_C3Round10)
    else
    endif
    if ( Trig_Main_Func037C() ) then
        call ConditionalTriggerExecute(gg_trg_C4Round1)
        call ConditionalTriggerExecute(gg_trg_C4Round2)
        call ConditionalTriggerExecute(gg_trg_C4Round3)
        call ConditionalTriggerExecute(gg_trg_C4Round4)
        call ConditionalTriggerExecute(gg_trg_C4Round5)
        call ConditionalTriggerExecute(gg_trg_C4Round6)
        call ConditionalTriggerExecute(gg_trg_C4Round7_Hm)
        call ConditionalTriggerExecute(gg_trg_C4Round8_Hm)
        call ConditionalTriggerExecute(gg_trg_C4Round9)
        call ConditionalTriggerExecute(gg_trg_C4Round10)
    else
    endif
    if ( Trig_Main_Func038C() ) then
        call ConditionalTriggerExecute(gg_trg_C5Round1)
        call ConditionalTriggerExecute(gg_trg_C5Round2)
        call ConditionalTriggerExecute(gg_trg_C5Round3)
        call ConditionalTriggerExecute(gg_trg_C5Round4)
        call ConditionalTriggerExecute(gg_trg_C5Round5)
        call ConditionalTriggerExecute(gg_trg_C5Round6)
        call ConditionalTriggerExecute(gg_trg_C5Round7)
        call ConditionalTriggerExecute(gg_trg_C5Round8)
        call ConditionalTriggerExecute(gg_trg_C5Round9)
        call ConditionalTriggerExecute(gg_trg_C5Round10_RH)
    else
    endif
    if ( Trig_Main_Func039C() ) then
        call ConditionalTriggerExecute(gg_trg_C6Round1_RH)
        call ConditionalTriggerExecute(gg_trg_C6Round2_RH_Hm)
        call ConditionalTriggerExecute(gg_trg_C6Round3_Hm)
        call ConditionalTriggerExecute(gg_trg_C6Round4_RH_Hm)
        call ConditionalTriggerExecute(gg_trg_C6Round5_RH)
        call ConditionalTriggerExecute(gg_trg_C6Round6_RH_Hm)
        call ConditionalTriggerExecute(gg_trg_C6Round7)
        call ConditionalTriggerExecute(gg_trg_C6Round8)
        call ConditionalTriggerExecute(gg_trg_C6Round9)
        call ConditionalTriggerExecute(gg_trg_C6Round10)
    else
    endif
    if ( Trig_Main_Func040C() ) then
        call ConditionalTriggerExecute(gg_trg_C7Round1_MW)
        call ConditionalTriggerExecute(gg_trg_C7Round2_MW)
        call ConditionalTriggerExecute(gg_trg_C7Round3_MW)
        call ConditionalTriggerExecute(gg_trg_C7Round4_EX)
        call ConditionalTriggerExecute(gg_trg_C7Round5_EX)
        call ConditionalTriggerExecute(gg_trg_C7Round6_EX)
        call ConditionalTriggerExecute(gg_trg_C7Round7_EX)
        call ConditionalTriggerExecute(gg_trg_C7Round8_MW)
        call ConditionalTriggerExecute(gg_trg_C7Round9_EX)
        call ConditionalTriggerExecute(gg_trg_C7Round10_EX)
    else
    endif
    if ( Trig_Main_Func041C() ) then
        call ConditionalTriggerExecute(gg_trg_C8Round1_MW)
        call ConditionalTriggerExecute(gg_trg_C8Round2_EX)
        call ConditionalTriggerExecute(gg_trg_C8Round3_EX)
        call ConditionalTriggerExecute(gg_trg_C8Round4_EX_Hm)
        call ConditionalTriggerExecute(gg_trg_C8Round5_EX_Hm)
        call ConditionalTriggerExecute(gg_trg_C8Round6_MW_Hm)
        call ConditionalTriggerExecute(gg_trg_C8Round7_EX_Hm)
        call ConditionalTriggerExecute(gg_trg_C8Round8_EX_Hm)
        call ConditionalTriggerExecute(gg_trg_C8Round9_MW_Hm)
        call ConditionalTriggerExecute(gg_trg_C8Round10_MW_Hm)
    else
    endif
    if ( Trig_Main_Func042C() ) then
        call ConditionalTriggerExecute(gg_trg_C9Round1_MW)
        call ConditionalTriggerExecute(gg_trg_C9Round3_EX)
        call ConditionalTriggerExecute(gg_trg_C9Round4_EX)
        call ConditionalTriggerExecute(gg_trg_C9Round5_MW_RH)
        call ConditionalTriggerExecute(gg_trg_C9Round6_MW_RH)
        call ConditionalTriggerExecute(gg_trg_C9Round7_EX_RH)
        call ConditionalTriggerExecute(gg_trg_C9Round8_EX_RH)
        call ConditionalTriggerExecute(gg_trg_C9Round2_MW)
        call ConditionalTriggerExecute(gg_trg_C9Round9_EX_RH)
        call ConditionalTriggerExecute(gg_trg_C9Round10_EX_RH)
    else
    endif
    if ( Trig_Main_Func043C() ) then
        call ConditionalTriggerExecute(gg_trg_C10Round1_MW)
        call ConditionalTriggerExecute(gg_trg_C10Round2_EX)
        call ConditionalTriggerExecute(gg_trg_C10Round3_EX)
        call ConditionalTriggerExecute(gg_trg_C10Round4_MW_Tree)
        call ConditionalTriggerExecute(gg_trg_C10Round5_EX_Tree)
        call ConditionalTriggerExecute(gg_trg_C10Round6_EX_Tree)
        call ConditionalTriggerExecute(gg_trg_C10Round7_MW_RH)
        call ConditionalTriggerExecute(gg_trg_C10Round8_MW_RH)
        call ConditionalTriggerExecute(gg_trg_C10Round9_EX)
        call ConditionalTriggerExecute(gg_trg_C10Round10_EX)
    else
    endif
    // UD Course Functions
    if ( Trig_Main_Func045C() ) then
        call CreateNUnitsAtLoc(1, 'nshe', Player(PLAYER_NEUTRAL_PASSIVE), GetRandomLocInRect(gg_rct_SheepStart), bj_UNIT_FACING)
        call CreateNUnitsAtLoc(1, 'e000', Player(PLAYER_NEUTRAL_PASSIVE), GetRectCenter(gg_rct_AntiMagicPlace), bj_UNIT_FACING)
    else
        call DoNothing()
    endif
    // Ne Course Functions
    if ( Trig_Main_Func047C() ) then
        call TriggerSleepAction(0.01)
        call ConditionalTriggerExecute(gg_trg_NeCoureF1_1_10)
    else
    endif
    if ( Trig_Main_Func048C() ) then
        call TriggerSleepAction(0.01)
        call ConditionalTriggerExecute(gg_trg_NeCoureF2_4_5_10)
    else
    endif
    // Hum Course Functions
    if ( Trig_Main_Func050C() ) then
        call ConditionalTriggerExecute(gg_trg_HumCoureF1_2_4_8)
    else
    endif
    if ( Trig_Main_Func051C() ) then
        call ConditionalTriggerExecute(gg_trg_HumCoureF2_6_8)
    else
    endif
    // Start
    call ConditionalTriggerExecute(gg_trg_Computer1Attack)
    call ConditionalTriggerExecute(gg_trg_Computer2Attack)
    call PingMinimapLocForForce(bj_FORCE_PLAYER[1], GetPlayerStartLocationLoc(Player(0)), 3.00)
    call PingMinimapLocForForce(bj_FORCE_PLAYER[0], GetPlayerStartLocationLoc(Player(1)), 3.00)
    call TriggerSleepAction(0.01)
    if ( Trig_Main_Func058C() ) then
        call ConditionalTriggerExecute(gg_trg_ComputerForceCountdown)
    else
        call DoNothing()
    endif
    // TreeMaker Functions
    call TriggerSleepAction(1.00)
    set udg_Treemaking=false
endfunction

