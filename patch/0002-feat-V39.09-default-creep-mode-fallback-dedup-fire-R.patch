index 0000000..74ee445
--- /dev/null
+++ b/wc3-ai-pipeline/inject_ai_spawn_offset.py
@@ -0,0 +1,64 @@
+#!/usr/bin/env python3
+"""
+inject_ai_spawn_offset.py
+Shift Race1Player spawn X by -500 for C3Round1 (OvU) and C5Round1 (UvN).
+Must run AFTER inject_ai_creep_control.py (operates on already-modified war3map.j).
+"""
+import sys, os
+
+def main():
+    if len(sys.argv) < 2:
+        print("Usage: inject_ai_spawn_offset.py <war3map.j>")
+        sys.exit(1)
+
+    path = sys.argv[1]
+    with open(path, 'rb') as f:
+        raw = f.read()
+    nl = b"\r\n" if b"\r\n" in raw[:4096] else b"\n"
+    src = raw.decode('utf-8', errors='replace')
+    nl_str = nl.decode()
+
+    ORIG_LOC  = 'GetPlayerStartLocationLoc(udg_Race1Player)'
+    OFFSET_LOC = ('Location('
+                  'GetLocationX(GetPlayerStartLocationLoc(udg_Race1Player)) - 500.0, '
+                  'GetLocationY(GetPlayerStartLocationLoc(udg_Race1Player)))')
+
+    target_fns = ['Trig_C3Round1_Actions', 'Trig_C5Round1_Actions']
+    lines = src.split(nl_str)
+    new_lines = []
+    in_target = False
+    fn_name = ''
+    counts = {}
+
+    for line in lines:
+        # detect function entry
+        for fn in target_fns:
+            if f'function {fn} takes nothing returns nothing' in line:
+                in_target = True
+                fn_name = fn
+                break
+
+        if in_target:
+            # detect end
+            if line.strip().startswith('endfunction') and fn_name and len(new_lines) > 10:
+                in_target = False
+                fn_name = ''
+            elif ('CreateNUnitsAtLoc' in line and
+                  'Race1Player' in line and
+                  ORIG_LOC in line):
+                line = line.replace(ORIG_LOC, OFFSET_LOC)
+                counts[fn_name] = counts.get(fn_name, 0) + 1
+
+        new_lines.append(line)
+
+    result = nl_str.join(new_lines)
+    with open(path, 'w', encoding='utf-8') as f:
+        f.write(result)
+
+    for fn, cnt in counts.items():
+        print(f"[SPAWN_OFFSET] {fn}: shifted {cnt} Race1Player spawns by -500 X")
+    if not counts:
+        print("WARN: no spawn lines patched, check function names")
+
+if __name__ == '__main__':
+    main()
